<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="..\SilksongPath.props" Condition="Exists('..\SilksongPath.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-1234-567890ABCDEF}</ProjectGuid>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>SSMPEnemyHealthSync</RootNamespace>
    <AssemblyName>SSMPEnemyHealthSync</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <!-- BepInEx -->
    <Reference Include="BepInEx">
      <HintPath>$(SilksongPluginsFolder)\BepInEx\core\BepInEx.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(SilksongPluginsFolder)\BepInEx\core\0Harmony.dll</HintPath>
      <Private>False</Private>
    </Reference>
    
    <!-- Unity -->
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(SilksongPluginsFolder)\BepInEx\core\UnityEngine.CoreModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    
    <!-- Silksong -->
    <Reference Include="Assembly-CSharp" Condition="Exists('$(SilksongGameFolder)\Hollow Knight Silksong_Data\Managed\Assembly-CSharp.dll')">
      <HintPath>$(SilksongGameFolder)\Hollow Knight Silksong_Data\Managed\Assembly-CSharp.dll</HintPath>
      <Private>False</Private>
    </Reference>
    
    <!-- SSMP -->
    <Reference Include="SSMP">
      <HintPath>$(SilksongPluginsFolder)\SSMP\SSMP.dll</HintPath>
      <Private>False</Private>
    </Reference>
    
    <!-- System -->
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="SSMPEnemyHealthSyncPlugin.cs" />
    <Compile Include="Client\*.cs" />
    <Compile Include="Server\*.cs" />
    <Compile Include="Utils\*.cs" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  
  <!-- Copy to plugins folder after build -->
  <Target Name="AfterBuild">
    <PropertyGroup>
      <PluginFolder>$(SilksongPluginsFolder)\SSMP.EnemyHealthSync</PluginFolder>
    </PropertyGroup>
    <MakeDir Directories="$(PluginFolder)" Condition="'$(SilksongPluginsFolder)' != ''" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(PluginFolder)" Condition="'$(SilksongPluginsFolder)' != ''" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFolder="$(PluginFolder)" Condition="'$(SilksongPluginsFolder)' != ''" />
    <Message Text="Copied to $(PluginFolder)" Importance="high" Condition="'$(SilksongPluginsFolder)' != ''" />
  </Target>
</Project>
